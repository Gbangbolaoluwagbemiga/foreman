# ─── Foreman environment ──────────────────────────────────────────────────────
# Copy to .env and fill in. The demo runs WITHOUT any of these (mock mode);
# fill them in to use the real Groq brain and real Arc USDC settlement.

# Groq (the agents' brain). Without it, Foreman falls back to deterministic mock reasoning.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Settlement rail: "mock" (default, no funds needed) or "arc-usdc" (real on-chain USDC transfers)
SETTLEMENT_RAIL=mock

# Arc Testnet (only needed when SETTLEMENT_RAIL=arc-usdc)
ARC_RPC_URL=https://rpc.drpc.testnet.arc.network
ARC_CHAIN_ID=5042002
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Foreman's own funded wallet private key (only for arc-usdc rail). Leave blank to auto-generate (unfunded).
FOREMAN_PRIVATE_KEY=
