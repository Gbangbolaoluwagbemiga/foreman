{
  "name": "foreman",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Give your AI a budget and a goal. It hires other AIs, pays each per task in USDC on Arc, and brings you the work plus a receipt.",
  "scripts": {
