    "gateway": "tsx src/gatewaydemo.ts",
    "gateway:job": "tsx src/gatewayjob.ts",
    "swarm": "tsx src/swarm.ts",
    "subcontract": "tsx src/subcontract.ts",
    "serve:gateway": "ENGINE_RAIL=gateway tsx src/server.ts",
    "agent": "tsx src/external-agent.ts",
    "mcp": "tsx src/mcp.ts"
  },
  "dependencies": {
    "@circle-fin/x402-batching": "^3.1.2",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@x402/evm": "^2.15.0",
    "dotenv": "^16.4.5",
    "groq-sdk": "^0.9.1",
    "viem": "^2.21.55",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
